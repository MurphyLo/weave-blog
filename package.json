{
  "name": "weave-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/gen-content-index.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/gen-content-index.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate:local": "wrangler d1 migrations apply weave-blog --local",
    "db:migrate:remote": "wrangler d1 migrations apply weave-blog --remote"
  },
  "dependencies": {
    "@number-flow/react": "^0.6.1",
    "@types/hast": "^3.0.4",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "motion": "^12.42.2",
    "next": "15.5.20",
    "next-mdx-remote-client": "^2.1.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-rough-notation": "^1.0.8",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-flexible-markers": "^1.3.5",
    "remark-flexible-toc": "^1.2.6",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260705.1",
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unist": "^3.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
